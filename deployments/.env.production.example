# HistorySync CE production deployment example.
# Copy to deployments/.env.production and replace every placeholder before use.
# Do not commit deployments/.env.production.

# Public endpoint served by your TLS reverse proxy.
HSYNC_PUBLIC_URL=https://sync.example.com

# Bind the app only to the reverse-proxy host interface by default.
HSYNC_BIND_ADDR=127.0.0.1
HSYNC_HTTP_PORT=8080
HSYNC_LOG_LEVEL=info

# PostgreSQL and Redis are created by docker-compose.production.yml.
POSTGRES_DB=hsync
POSTGRES_PASSWORD=<replace-with-postgres-password>
REDIS_PASSWORD=<replace-with-redis-password>
REDIS_MAXMEMORY=512mb

# Object storage is external to this compose stack.
HSYNC_S3_ENDPOINT=s3.example.com
HSYNC_S3_BUCKET=hsync-bundles
HSYNC_S3_ACCESS_KEY=<replace-with-s3-access-key>
HSYNC_S3_SECRET_KEY=<replace-with-s3-secret-key>
HSYNC_S3_USE_SSL=true

# Generate both keys with: openssl rand -base64 32
HSYNC_JWT_PRIVATE_KEY=<replace-with-base64-32-byte-ed25519-seed>
HSYNC_SECURITY_SECRET=<replace-with-base64-32-byte-secret>

# Required for CE /admin and /api/v1/admin routes.
HSYNC_ADMIN_KEY=<replace-with-long-random-admin-key>

# Keep /metrics private. If enabled, the app also enforces configured CIDRs.
HSYNC_METRICS_ENABLED=false

# CE production stack does not configure commercial billing providers.
HSYNC_STRIPE_DISABLED=true
