# HistorySync Cloud Server - Environment Variables
# Copy this file to .env and fill in the values.

# ── Required ─────────────────────────────────────────────
HSYNC_DATABASE_URL=postgres://hsync:hsync@localhost:5432/hsync?sslmode=disable
HSYNC_JWT_PRIVATE_KEY=<base64-encoded 32-byte Ed25519 seed>
HSYNC_SECURITY_SECRET=<base64-encoded 32-byte encryption key>

# ── Optional ─────────────────────────────────────────────
HSYNC_REDIS_URL=redis://localhost:6379/0
HSYNC_LISTEN_ADDR=:8080
HSYNC_LOG_LEVEL=info

# ── S3 / MinIO ───────────────────────────────────────────
HSYNC_S3_ENDPOINT=localhost:9000
HSYNC_S3_BUCKET=hsync-bundles
HSYNC_S3_ACCESS_KEY=minioadmin
HSYNC_S3_SECRET_KEY=minioadmin
HSYNC_S3_USE_SSL=false

# ── Stripe (set HSYNC_STRIPE_DISABLED=true for self-hosted) ─
HSYNC_STRIPE_DISABLED=true
# HSYNC_STRIPE_SECRET_KEY=sk_live_...
# HSYNC_STRIPE_WEBHOOK_SECRET=whsec_...

# Gumroad / Afdian payment webhooks
# HSYNC_GUMROAD_WEBHOOK_SECRET=<shared-secret>
# HSYNC_AFDIAN_WEBHOOK_TOKEN=<afdian-api-token>

# ── Admin ────────────────────────────────────────────────
# HSYNC_ADMIN_KEY=<your-secret-admin-key>

# Cloudflare Turnstile bot protection for public auth routes.
HSYNC_TURNSTILE_ENABLED=false
# HSYNC_TURNSTILE_SECRET=0x...
# HSYNC_TURNSTILE_SITE_KEY=0x...
HSYNC_TURNSTILE_TIMEOUT=3s

# Background ops checks and alert hooks
HSYNC_OPS_DEPENDENCY_CHECK_INTERVAL=6h
HSYNC_OPS_CONSISTENCY_CHECK_INTERVAL=24h
HSYNC_OPS_CONSISTENCY_CHECK_LIMIT=1000
# HSYNC_OPS_ALERT_EMAIL=ops@example.com
# HSYNC_OPS_ALERT_WEBHOOK_URL=https://hooks.example.com/historysync-ops
# HSYNC_OPS_ALERT_WEBHOOK_SECRET=<shared-secret>
